---
import '../styles/global.css';
import Sidebar from '../components/ui/Sidebar';
import Toast from '../components/ui/Toast';
import JobContextModal from '../components/JobContextModal';

interface Props {
  title?: string;
}

const { title = 'Rattle-Snake' } = Astro.props;
const pathname = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Rattle-Snake</title>
    <link rel="icon" type="image/png" href="/rattle-snake.png" />
    <link rel="alternate icon" href="/rattle-snake.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen flex flex-col">
    <!-- Sidebar -->
    <Sidebar currentPath={pathname} client:load />

    <!-- Main content -->
    <main class="ml-56 flex-1">
      <div class="max-w-6xl mx-auto px-8 py-8">
        <slot />
      </div>
    </main>

    <!-- Toast notifications -->
    <Toast client:load />

    <!-- Job Context Modal — global, triggered from anywhere via useJobContext().openModal() -->
    <JobContextModal client:load />

    <!-- Footer -->
    <footer class="ml-56 mt-auto py-10" style="border-top: 0.5px solid #1e293b;">
      <div class="max-w-6xl mx-auto px-8">
        <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">

          <!-- Rattle Snake Logo -->
          <div class="flex shrink-0 items-start">
            <a href="https://rattlesnake.onlynerds.win" target="_blank" rel="noopener noreferrer">
              <img src="/rattle-snake.png" alt="Rattle-Snake" class="transition-opacity duration-300 hover:opacity-100" style="height: 7rem; opacity: 0.85;" />
            </a>
          </div>

          <!-- Built in Association With -->
          <div>
            <p class="mb-4 font-mono text-[10px] font-semibold uppercase tracking-[0.22em] text-slate-400">Built in Association With</p>
            <div class="flex flex-col gap-3">
              <a href="https://onlynerds.win" target="_blank" rel="noopener noreferrer"
                class="group inline-flex items-center gap-2.5 px-3 py-2 transition-all duration-300 hover:bg-slate-800/60"
                style="border: 0.5px solid #1e293b;"
                onmouseover="this.style.borderColor='#475569'" onmouseout="this.style.borderColor='#1e293b'">
                <img src="/OnlyNerds_Nav.svg" alt="OnlyNerds" class="h-5 w-auto object-contain" />
                <span class="font-mono text-xs font-semibold text-slate-300 group-hover:text-white transition-colors">OnlyNerds</span>
              </a>
              <a href="https://alphonso.app" target="_blank" rel="noopener noreferrer"
                class="group inline-flex items-center gap-2.5 px-3 py-2 transition-all duration-300 hover:bg-slate-800/60"
                style="border: 0.5px solid #1e293b;"
                onmouseover="this.style.borderColor='#475569'" onmouseout="this.style.borderColor='#1e293b'">
                <img src="/Alphonso.svg" alt="Alphonso AI" class="h-5 w-auto object-contain" />
                <span class="font-mono text-xs font-semibold text-slate-300 group-hover:text-white transition-colors">Alphonso AI</span>
              </a>
            </div>
          </div>

          <!-- Created By -->
          <div>
            <p class="mb-4 font-mono text-[10px] font-semibold uppercase tracking-[0.22em] text-slate-400">Created By</p>
            <p class="mb-0.5 font-sans text-sm font-semibold text-slate-100">Pavan Yellathakota</p>
            <p class="mb-4 font-mono text-xs text-slate-400">Data Scientist &amp; ML Practitioner</p>
            <div class="flex flex-wrap gap-2">
              <a href="https://pye.pages.dev" target="_blank" rel="noopener noreferrer"
                class="font-mono text-[10px] uppercase tracking-[0.1em] text-slate-400 hover:text-slate-100 transition-colors px-2.5 py-1.5"
                style="border: 0.5px solid #1e293b;"
                onmouseover="this.style.borderColor='#475569'" onmouseout="this.style.borderColor='#1e293b'">Portfolio</a>
              <a href="https://github.com/yellatp" target="_blank" rel="noopener noreferrer"
                class="font-mono text-[10px] uppercase tracking-[0.1em] text-slate-400 hover:text-slate-100 transition-colors px-2.5 py-1.5"
                style="border: 0.5px solid #1e293b;"
                onmouseover="this.style.borderColor='#475569'" onmouseout="this.style.borderColor='#1e293b'">GitHub</a>
              <a href="https://linkedin.com/in/yellatp" target="_blank" rel="noopener noreferrer"
                class="font-mono text-[10px] uppercase tracking-[0.1em] text-slate-400 hover:text-slate-100 transition-colors px-2.5 py-1.5"
                style="border: 0.5px solid #1e293b;"
                onmouseover="this.style.borderColor='#475569'" onmouseout="this.style.borderColor='#1e293b'">LinkedIn</a>
              <a href="mailto:pavan.yellathakota.ds@gmail.com"
                class="font-mono text-[10px] uppercase tracking-[0.1em] text-slate-400 hover:text-slate-100 transition-colors px-2.5 py-1.5"
                style="border: 0.5px solid #1e293b;"
                onmouseover="this.style.borderColor='#475569'" onmouseout="this.style.borderColor='#1e293b'">Email</a>
            </div>
          </div>

        </div>

        <!-- Bottom bar -->
        <div class="mt-8 pt-6 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between" style="border-top: 0.5px solid #1e293b;">
          <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-slate-500">© 2026 Rattle-Snake</p>
          <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-slate-500">
            Licensed under <a href="/LICENSE" class="text-slate-400 underline hover:text-slate-200 transition-colors ml-1">Apache 2.0</a>
          </p>
        </div>
      </div>
    </footer>

    <!-- Global keyboard shortcuts (never fires when focus is inside a form field) -->
    <script>
      function isTypingTarget(el: EventTarget | null): boolean {
        if (!(el instanceof HTMLElement)) return false;
        const tag = el.tagName;
        return tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT' || el.isContentEditable;
      }

      document.addEventListener('keydown', (e) => {
        if (isTypingTarget(e.target)) return;
        if (e.metaKey || e.ctrlKey || e.altKey) return;

        if (e.key === 'g' || e.key === 'G') {
          const handler = (e2: KeyboardEvent) => {
            if (isTypingTarget(e2.target)) {
              document.removeEventListener('keydown', handler);
              return;
            }
            document.removeEventListener('keydown', handler);
            const map: Record<string, string> = {
              'd': '/', 'g': '/generate',
              'a': '/applications',
              'i': '/interview-prep', 'p': '/profile', 's': '/settings',
            };
            const target = map[e2.key.toLowerCase()];
            if (target) window.location.href = target;
          };
          setTimeout(() => document.removeEventListener('keydown', handler), 1000);
          document.addEventListener('keydown', handler);
        }
      });
    </script>
  </body>
</html>
