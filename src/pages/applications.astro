---
import Layout from '../layouts/Layout.astro';
import ApplicationsTable from '../components/ApplicationsTable';
---

<Layout title="All Applications">
  <div class="space-y-6">
    <div class="flex items-center gap-4">
      <a href="/" class="text-slate-500 hover:text-slate-300 transition-colors text-sm">← Dashboard</a>
      <div>
        <h1 class="text-2xl font-bold text-slate-100">All Applications</h1>
        <p class="text-sm text-slate-500 mt-0.5">Full history — sort, filter, and manage every tracked application.</p>
      </div>
    </div>

    <ApplicationsTable client:only="react" />
  </div>
</Layout>
